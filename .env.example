# Copie este arquivo para ".env" e ajuste os valores na sua máquina.
# O .env de verdade NUNCA vai para o Git (está no .gitignore).

# --- Banco de dados ---
# Para usar PostgreSQL local (recomendado em desenvolvimento):
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cardiotrack
# Para cair no plano B em SQLite, basta comentar a linha acima e usar:
# DATABASE_URL=sqlite:///./cardiotrack.db

# --- Segurança (JWT) ---
# Gere uma chave forte e secreta. Em produção, jamais deixe a padrão.
JWT_SECRET=troque-esta-chave-por-uma-bem-grande-e-aleatoria
JWT_EXPIRACAO_MINUTOS=120
